<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_window_bg"
    android:padding="8dp"
    android:elevation="8dp">

    <TextView
        android:id="@+id/tvFloatingStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BD2 Bot"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnFloatingStart"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/floating_start"
            android:textSize="10sp"
            android:padding="4dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnFloatingPause"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/floating_pause"
            android:textSize="10sp"
            android:padding="4dp"
            android:layout_marginEnd="2dp" />

        <Button
            android:id="@+id/btnFloatingStop"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="@string/floating_stop"
            android:textSize="10sp"
            android:padding="4dp" />

    </LinearLayout>

</LinearLayout>
